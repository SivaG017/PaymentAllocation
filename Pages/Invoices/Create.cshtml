@page
@model PaymentAllocation.Pages.Invoices.CreateModel
@{
    ViewData["Title"] = "Create Invoice";
}

<div class="page-shell">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Invoice workflow</p>
            <h1>Create invoice</h1>
            <p class="lead">Capture the invoice header and line items, then the ledger charges are posted automatically.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Index">Back to dashboard</a>
    </div>

    <form method="post" class="stacked-form">
        <div class="panel">
            <div class="panel-body">
                <div class="row g-3">
                    <div class="col-lg-6">
                        <label asp-for="Input.CustomerReference" class="form-label"></label>
                        <input asp-for="Input.CustomerReference" class="form-control" placeholder="CUST-10001" />
                        <span asp-validation-for="Input.CustomerReference" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="panel">
            <div class="panel-body">
                <div class="section-head">
                    <div>
                        <h2>Line items</h2>
                        <p>Add each outstanding item with its own due date.</p>
                    </div>
                    <button class="btn btn-primary" type="submit" formaction="?handler=AddLine">Add line</button>
                </div>

                <div class="line-item-list">
                    @for (var i = 0; i < Model.Input.LineItems.Count; i++)
                    {
                        <div class="line-item-row">
                            <div>
                                <label class="form-label">Description</label>
                                <input asp-for="Input.LineItems[i].Description" class="form-control" placeholder="Funding tranche" />
                            </div>
                            <div>
                                <label class="form-label">Amount</label>
                                <input asp-for="Input.LineItems[i].Amount" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                            <div>
                                <label class="form-label">Due date</label>
                                <input asp-for="Input.LineItems[i].DueDate" class="form-control" type="date" />
                            </div>
                            <div class="line-item-actions">
                                <button class="btn btn-outline-danger" type="submit" formaction="?handler=RemoveLine&amp;index=@i">Remove</button>
                            </div>
                        </div>
                    }
                </div>

                <span asp-validation-summary="All" class="text-danger"></span>
            </div>
        </div>

        <div class="actions-bar">
            <button type="submit" class="btn btn-success">Create invoice</button>
        </div>
    </form>
</div>
